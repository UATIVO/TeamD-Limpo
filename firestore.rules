rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'SimonKamina2014@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt']) &&
                      incoming().role in ['admin', 'student'] &&
                      incoming().uid == request.auth.uid;
      allow update: if (isOwner(userId) && 
                      incoming().diff(resource.data).affectedKeys().hasOnly(['name', 'points', 'updatedAt', 'lastResetMonth', 'photoUrl', 'age', 'objective', 'studiedExercises', 'lastWeeklyPointsKey', 'theme'])) ||
                      isAdmin();
    }

    // --- Exercises ---
    match /exercises/{exerciseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Workouts ---
    match /workouts/{workoutId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if (isAdmin()) || 
                      (isSignedIn() && resource.data.studentId == request.auth.uid &&
                       incoming().diff(resource.data).affectedKeys().hasOnly(['exercises', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // --- Workout Logs ---
    match /workout_logs/{logId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    // --- Exercise Knowledge (Cache) ---
    match /exercise_knowledge/{docId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
